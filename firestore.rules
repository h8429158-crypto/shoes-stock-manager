rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only signed-in accounts can read or change the stock.
    match /shoes/{shoeId} {
      allow read, write: if request.auth != null;
    }

    // Sales history — signed-in accounts can view and add sales.
    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }
  }
}
